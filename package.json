name: Scrape Jackpots

on:
  schedule:
    - cron: '0 * * * *'   # toutes les heures pile
  workflow_dispatch:        # bouton manuel dans GitHub

jobs:
  scrape:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout du dépôt
        uses: actions/checkout@v4

      - name: Installation de Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'

      - name: Installation des dépendances
        run: npm install

      - name: Lancement du scraping
        env:
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
          DATA_DIR: '.'
        run: node scraper.js

      - name: Commit et push de latest.json
        run: |
          git config user.name "github-actions"
          git config user.email "github-actions@github.com"
          git add latest.json
          git diff --staged --quiet || git commit -m "snapshot $(date -u +'%Y-%m-%d %H:%M')"
          git push
